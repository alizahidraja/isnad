                </mxCell>
                <mxCell id="layer0_label" value="LAYER 0 — Types, Enums &amp; Protocols (isnad/types.py, isnad/models.py)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#444444;" parent="1" vertex="1">
                    <mxGeometry x="80" y="100" width="550" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="grades_box" value="&lt;b&gt;Ordinal Grades&lt;/b&gt;&lt;br&gt;NarratorGrade: RELIABLE &gt; ACCEPTABLE &gt; WEAK &gt; REJECTED &gt; UNGRADED&lt;br&gt;ChainGrade: SAHIH &gt; HASAN &gt; DAIF &gt; MAWDU&lt;br&gt;AdalahGrade: integrity axis (5 tiers)&lt;br&gt;DabtGrade: precision axis (4 tiers)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="80" y="130" width="380" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="tax_box" value="&lt;b&gt;Taxonomy &amp; Actions&lt;/b&gt;&lt;br&gt;TransformType: DESTRUCTIVE | GENERATIVE | PASS_THROUGH&lt;br&gt;NarratorType: SOURCE | SCRAPER | MODEL | HUMAN&lt;br&gt;ContentVerdict: CONSISTENT | CONTRADICTION | UNVERIFIABLE&lt;br&gt;Action: SERVE | SERVE_WITH_CAVEAT | REVIEW | QUARANTINE | REJECT&lt;br&gt;ChainStatus: COMPLETE | MUNQATI | ACTIVE | SUPERSEDED" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="480" y="130" width="550" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="ev_box" value="&lt;b&gt;Evidence System&lt;/b&gt;&lt;br&gt;EvidenceType: EVAL_HARNESS | POST_HOC_AUDIT | CORROBORATION_OUTCOME&lt;br&gt;    HUMAN_REVIEW | VERSION_BUMP | BOOTSTRAP_SEED&lt;br&gt;EvidenceAction: JARH (adverse) | TADIL (positive) | NEUTRAL" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="1050" y="130" width="410" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="proto_box" value="&lt;b&gt;Pluggable Strategy Protocols (types.py)&lt;/b&gt;&lt;br&gt;GradingStrategy .compute_chain_grade()&lt;br&gt;TransitionPolicy .evaluate_transition()&lt;br&gt;CorroborationPolicy .compute_corroborated_grade()&lt;br&gt;CorrelationDetector .are_independent() / .compute_independence_score()&lt;br&gt;ContentCritic .evaluate() → ContentVerdict" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="1050" y="205" width="410" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="orm_box" value="&lt;b&gt;Pydantic DTOs &amp; SQLAlchemy ORM (models.py)&lt;/b&gt;&lt;br&gt;DTOs: ChainLinkDTO | NarratorDTO | EvidenceDTO | ReviewQueueItemDTO&lt;br&gt;ORM: RijalClaim | ChainLink | NarratorRegistry | NarratorEvidence | ReviewQueue&lt;br&gt;Schema: 5 tables, composite PKs, append-only evidence log, lifecycle supersession" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="80" y="240" width="950" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="layer1_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;dashed=1;opacity=40;" parent="1" vertex="1">
                    <mxGeometry x="60" y="320" width="1680" height="390" as="geometry"/>
                </mxCell>
                <mxCell id="layer1_label" value="LAYER 1 — Core Engine (isnad/core/)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#1565c0;" parent="1" vertex="1">
                    <mxGeometry x="80" y="325" width="350" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="chain_box" value="&lt;b&gt;chain.py — Transmission Chain (isnād)&lt;/b&gt;&lt;br&gt;&lt;br&gt;🔗 ChainLinkSpec: narrator_id, step, version, transform_type, trace_id, domain&lt;br&gt;🔗 Chain: ordered links → gap-check .is_complete (ittiṣāl)&lt;br&gt;   .chain_status → COMPLETE | MUNQATI&lt;br&gt;🔗 normalize_claim_text() + SHA-256 → make_claim_id()&lt;br&gt;🔗 store_claim() → writes RijalClaim + ChainLink to DB&lt;br&gt;🔗 get_chain_from_db() → reconstructs Chain from normalized links&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ 157 unit/integration tests pass&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="80" y="355" width="370" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="reg_box" value="&lt;b&gt;registry.py — Rijāl Registry (jarḥ–taʿdīl)&lt;/b&gt;&lt;br&gt;&lt;br&gt;📋 Narrator: keyed by (narrator_id, domain) — domain-conditioned&lt;br&gt;   .grade, .adalah_grade, .dabt_grade, .evidence_log (append-only)&lt;br&gt;   .model_family, .upstream_source (for correlation detection)&lt;br&gt;📋 Registry: in-memory store (pure logic, no DB)&lt;br&gt;   .register() | .get_grade() | .get_metadata() | .quarantine() | .bump_version()&lt;br&gt;📋 RegistryDB: SQLAlchemy-backed persistent wrapper&lt;br&gt;   .load() from DB | .flush() to DB&lt;br&gt;📋 BayesianTransitionPolicy (DEFAULT): Beta(α,β) posterior → grade&lt;br&gt;📋 ThresholdTransitionPolicy: hardcoded counts (legacy fallback)&lt;br&gt;📋 CalibratedThresholdPolicy: data-driven thresholds&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ Bayesian default | seed-grade bootstrapping validated&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="470" y="355" width="400" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="grading_box" value="&lt;b&gt;grading.py — Chain Grading (weakest-link)&lt;/b&gt;&lt;br&gt;&lt;br&gt;⚖️ RefinedWeakestLink (default GradingStrategy)&lt;br&gt;   Walks chain link-by-link, maintaining a running floor:&lt;br&gt;   → DESTRUCTIVE: permanent hard floor (info lost, unrecoverable)&lt;br&gt;   → GENERATIVE + corroboration + grade ≥ ACCEPTABLE: REPLACES floor&lt;br&gt;      (can repair upstream damage OR introduce new corruption)&lt;br&gt;   → GENERATIVE (no corroboration) or PASS_THROUGH: standard min&lt;br&gt;   → Incomplete chain (munqaṭiʿ) → capped at DAIF&lt;br&gt;   → Any REJECTED narrator → MAWDU immediately&lt;br&gt;⚖️ grade_chain() convenience function (defaults to RefinedWeakestLink)&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ 17 grading tests | pluggable via GradingStrategy protocol&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="890" y="355" width="440" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="corr_box" value="&lt;b&gt;corroboration.py — Mutābaʿāt (independent-chain upgrade)&lt;/b&gt;&lt;br&gt;&lt;br&gt;🔄 SharedLineageDetector (default CorrelationDetector)&lt;br&gt;   .are_independent() → checks shared ID, model family, upstream source&lt;br&gt;   .compute_independence_score() → 1.0 = fully independent, 0.0 = correlated&lt;br&gt;   Penalties: shared ID → 0.0, shared family → -0.4, shared source → -0.3&lt;br&gt;🔄 CappedCorroborationPolicy (info-theoretic, default CorroborationPolicy)&lt;br&gt;   Combined error ∝ Π p_i, effective_weight = Σ ln(p_i) / ln(p_hasan)&lt;br&gt;   MIN_EFFECTIVE_WEIGHT = 2.0, max upgrade = 1 tier, never reaches SAHIH&lt;br&gt;🔄 CorroborationEngine: .evaluate() (exact text) | .evaluate_direct() (pre-matched)&lt;br&gt;🔄 evaluate_corroboration() | find_corroborating_claims()&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ Empirically validated: 603/603 upgrades (100%) | 8/8 negative controls&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="470" y="575" width="440" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="decision_box" value="&lt;b&gt;decision.py — Decision Matrix (4×2 action router)&lt;/b&gt;&lt;br&gt;&lt;br&gt;🎯 decide(chain_grade, content_verdict) → Action&lt;br&gt;   SAHIH × CONSISTENT → SERVE (cache)&lt;br&gt;   SAHIH × CONTRADICTION → REVIEW (ʿilal — highest-value case)&lt;br&gt;   HASAN × CONSISTENT → SERVE_WITH_CAVEAT (seek corroboration)&lt;br&gt;   HASAN × CONTRADICTION → REVIEW (hold, do not serve)&lt;br&gt;   DAIF × CONSISTENT → REVIEW (seek corroboration first)&lt;br&gt;   DAIF × CONTRADICTION → QUARANTINE&lt;br&gt;   MAWDU × ANY → REJECT_AND_QUARANTINE_NARRATOR&lt;br&gt;🎯 describe_action() → human-readable reasoning&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ All 12 cells tested, all 5 actions covered&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="80" y="545" width="370" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="layer2_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;dashed=1;opacity=40;" parent="1" vertex="1">
                    <mxGeometry x="60" y="725" width="1680" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="layer2_label" value="LAYER 2 — Content Critics + Matn (isnad/critics/, isnad/matn.py)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#2e7d32;" parent="1" vertex="1">
                    <mxGeometry x="80" y="730" width="550" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="matn_box" value="&lt;b&gt;matn.py — DeterministicRuleCritic&lt;/b&gt;&lt;br&gt;📝 Reference stub: 8 hardcoded contradiction patterns&lt;br&gt;📝 .evaluate() → ContentVerdict&lt;br&gt;📝 .add_pattern() to extend&lt;br&gt;&lt;font color=&quot;#ff9800&quot;&gt;⚠️ STUB — only matches exact patterns; UNVERIFIABLE on real text&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="80" y="760" width="370" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="critic_embed" value="&lt;b&gt;embedding.py — EmbeddingCritic (DEFAULT)&lt;/b&gt;&lt;br&gt;📊 TF-IDF weighted cosine similarity (zero dependencies)&lt;br&gt;📊 TFIDFIndex: term frequency × inverse doc frequency&lt;br&gt;📊 Contradiction heuristics: negation, opposite words, numeric divergence &gt;3x&lt;br&gt;📊 thresholds: sim ≥ 0.75 → CONSISTENT, sim ≥ 0.50 → check contradiction&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ Functional, fast, offline | Default critic for API&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="470" y="760" width="400" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="critic_nli" value="&lt;b&gt;nli.py — LocalNLICritic &amp; HybridCritic&lt;/b&gt;&lt;br&gt;🤖 LocalNLICritic: DeBERTa cross-encoder NLI (require[s] sentence-transformers)&lt;br&gt;   Entailment threshold ≥ 0.65 → CONSISTENT | Contradiction ≥ 0.55 → CONTRADICTION&lt;br&gt;🤖 HybridCritic: 2-stage — MiniLM retrieval (top-k) → DeBERTa NLI judgment&lt;br&gt;   Best accuracy/performance trade-off for production&lt;br&gt;&lt;font color=&quot;#1976d2&quot;&gt;✅ Functional | Optional dep (~500MB model download)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="890" y="760" width="440" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="critic_llm" value="&lt;b&gt;llm.py — LLMCritic&lt;/b&gt;&lt;br&gt;🧠 Anthropic Claude-backed (retrieval-augmented)&lt;br&gt;🧠 TF-IDF retrieval → top-k corpus context → LLM prompt → verdict&lt;br&gt;🧠 Disk caching (keyed by claim + context hash)&lt;br&gt;🧠 Graceful degradation: returns UNVERIFIABLE if no API key&lt;br&gt;&lt;font color=&quot;#ff9800&quot;&gt;⚠️ Needs ANTHROPIC_API_KEY | Not benchmarked at scale&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="80" y="850" width="650" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="critic_eval" value="&lt;b&gt;eval.py — Critic Evaluation Harness&lt;/b&gt;&lt;br&gt;🧪 Benchmarks critics on labeled dataset&lt;br&gt;🧪 Measures precision, recall, F1, false-consistent rate&lt;br&gt;&lt;font color=&quot;#1976d2&quot;&gt;✅ Wired | Needs standardized benchmarks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="750" y="850" width="380" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="layer3_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;dashed=1;opacity=35;" parent="1" vertex="1">
                    <mxGeometry x="60" y="940" width="1680" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="layer3_label" value="LAYER 3 — API, CLI &amp; Integrations (isnad/api/, isnad/cli/, isnad/integrations/)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#c62828;" parent="1" vertex="1">
                    <mxGeometry x="80" y="945" width="650" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="api_box" value="&lt;b&gt;api/ — FastAPI Service&lt;/b&gt;&lt;br&gt;🔌 app.py: create_app() factory with lifespan, CORS, Prometheus&lt;br&gt;🔌 auth.py: API key auth (X-API-Key header, admin/reader roles)&lt;br&gt;🔌 dependencies.py: DI — get_db(), get_registry(), get_critic()&lt;br&gt;   Warm-start seeds from ISNAD_SEED_CONFIG env var&lt;br&gt;   Policy selection: ISNAD_POLICY=bayesian|threshold&lt;br&gt;🔌 endpoints/claims.py: POST/GET /v1/claims — full lifecycle&lt;br&gt;   Chain building → grading → corroboration → criticism → decision&lt;br&gt;🔌 endpoints/narrators.py: POST/GET /v1/narrators, POST /v1/evidence&lt;br&gt;🔌 endpoints/health.py: /v1/health, /metrics (Prometheus format)&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ All endpoints tested | DI overridable | Prometheus metrics&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="80" y="975" width="580" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="cli_box" value="&lt;b&gt;cli/ — CLI Entry Point&lt;/b&gt;&lt;br&gt;🖥️ isnad serve → uvicorn.run(&quot;isnad.api.app:app&quot;)&lt;br&gt;🖥️ isnad seed → reads ISNAD_SEED_CONFIG JSON&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ Wired as project.scripts entry point&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="680" y="975" width="380" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="lc_box" value="&lt;b&gt;integrations/langchain/&lt;/b&gt;&lt;br&gt;🔌 tracer.py: IsnadTracer — LangChain callback handler&lt;br&gt;   Auto-builds chains from LLM/retriever/tool callbacks&lt;br&gt;🔌 decorator.py: @isnad_track — function-level provenance&lt;br&gt;🔌 helpers.py: seed_registry() — warm-start from dict&lt;br&gt;   CriticAdapter — plug any callable as ContentCritic&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ 9 integration tests pass&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="680" y="1038" width="450" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="layer4_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#5c6bc0;dashed=1;opacity=35;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1095" width="1680" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="layer4_label" value="LAYER 4 — Storage, Experiments &amp; Infrastructure" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#3949ab;" parent="1" vertex="1">
                    <mxGeometry x="80" y="1100" width="450" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="storage_box" value="&lt;b&gt;storage/ — Persistence Layer&lt;/b&gt;&lt;br&gt;💾 base.py: RegistryPersistence protocol (swap backend)&lt;br&gt;💾 sqlalchemy.py: init_db(), get_session(), get_engine()&lt;br&gt;   Supports PostgreSQL (production) + SQLite (testing)&lt;br&gt;   ISNAD_DATABASE_URL env var&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ SQLAlchemy 2.0+ | Alembic migrations&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="80" y="1130" width="380" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="exp_box" value="&lt;b&gt;experiments/ — Empirical Validation&lt;/b&gt;&lt;br&gt;🧪 s8_gated_vs_ungated/: 4-condition serving experiment (10 seeds × 4 budgets)&lt;br&gt;🧪 corroboration_v2/: semantic corroboration on dual Wikipedia corpus (30 topics)&lt;br&gt;🧪 corroboration_v1/: initial within-topic exact-match corroboration&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ Corroboration validated | Gating experiment wired&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="480" y="1130" width="520" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="infra_box" value="&lt;b&gt;Infrastructure&lt;/b&gt;&lt;br&gt;🐳 Dockerfile: multi-stage (Python 3.12-slim, UV, NLI pre-download)&lt;br&gt;🐳 docker-compose.yml: API + PostgreSQL 16 + Redis 7 + Prometheus&lt;br&gt;📦 pyproject.toml: extras [dev,anthropic,langchain,api,nli,all]&lt;br&gt;🔧 alembic/: database migrations (initial schema: 5 tables + indexes)&lt;br&gt;🔧 prometheus.yml: scrape config for /metrics endpoint" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="1020" y="1130" width="400" height="85" as="geometry"/>
                </mxCell>
