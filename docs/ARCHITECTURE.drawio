    </diagram>
    <diagram id="dataflow" name="2. Claim Lifecycle">
        <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title2" value="Claim Lifecycle — End-to-End Data Flow &amp; Decision Routing" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
                    <mxGeometry x="350" y="15" width="900" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="s1" value="&lt;b&gt;1. CLAIM INGESTION&lt;/b&gt;&lt;br&gt;&lt;br&gt;Source: Wikipedia, PDF, API, DB&lt;br&gt;Extraction: sentence-split, OCR,&lt;br&gt;  LLM claim extraction&lt;br&gt;→ Text + source metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=12;align=center;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="60" y="80" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="a1" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976d2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s1" target="s2">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s2" value="&lt;b&gt;2. CHAIN BUILDING&lt;/b&gt;&lt;br&gt;(core/chain.py)&lt;br&gt;&lt;br&gt;ChainLinkSpec per step:&lt;br&gt;  narrator_id, step, version,&lt;br&gt;  transform_type, trace_id,&lt;br&gt;  domain, confidence&lt;br&gt;→ Chain(links) built&lt;br&gt;→ gap-check: .is_complete&lt;br&gt;→ normalize + SHA-256 ID&lt;br&gt;→ store_claim() → DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=11;align=center;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="300" y="70" width="210" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="a2" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976d2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s2" target="s3">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s3" value="&lt;b&gt;3. NARRATOR LOOKUP&lt;/b&gt;&lt;br&gt;(core/registry.py)&lt;br&gt;&lt;br&gt;Registry.get_grade(narrator_id, domain)&lt;br&gt;→ per-link NarratorGrade&lt;br&gt;BayesianTransitionPolicy (DEFAULT):&lt;br&gt;  Beta(α,β) posterior → grade&lt;br&gt;  seed grades from ISNAD_SEED_CONFIG&lt;br&gt;ThresholdTransitionPolicy (fallback)&lt;br&gt;→ list[NarratorGrade] per link" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=11;align=center;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="550" y="65" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="a3" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976d2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s3" target="s4">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s4" value="&lt;b&gt;4. CHAIN GRADING&lt;/b&gt;&lt;br&gt;(core/grading.py)&lt;br&gt;&lt;br&gt;RefinedWeakestLink walks chain:&lt;br&gt;  DESTRUCTIVE → hard floor&lt;br&gt;  GENERATIVE → can repair&lt;br&gt;  PASS_THROUGH → min&lt;br&gt;Incomplete chain → DAIF cap&lt;br&gt;REJECTED narrator → MAWDU&lt;br&gt;→ ChainGrade (SAHIH..MAWDU)&lt;br&gt;grade_chain() convenience fn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=11;align=center;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="830" y="62" width="230" height="135" as="geometry"/>
                </mxCell>
                <mxCell id="fork_corr" value="Corroboration?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ff9800;fontSize=11;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="1120" y="90" width="100" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="a4" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976d2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s4" target="fork_corr">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="corr_yes_label" value="YES" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#28a745;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="1175" y="175" width="40" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="a_corr_yes" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#28a745;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="fork_corr" target="s5a">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1170" y="255"/>
                            <mxPoint x="1170" y="255"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s5a" value="&lt;b&gt;5a. CORROBORATION (mutābaʿāt)&lt;/b&gt;&lt;br&gt;(core/corroboration.py)&lt;br&gt;&lt;br&gt;CorroborationEngine:&lt;br&gt;  .evaluate_direct() ← pre-matched chains&lt;br&gt;  .evaluate() ← exact text match&lt;br&gt;1) Independence check (madār)&lt;br&gt;   SharedLineageDetector&lt;br&gt;2) Min grade gate (≥ HASAN)&lt;br&gt;3) Count gate (≥ min_independent)&lt;br&gt;4) Info-theoretic weight:&lt;br&gt;   effective_weight = Σln(pᵢ)/ln(p_hasan)&lt;br&gt;   Fire if ≥ 2.0&lt;br&gt;→ Upgraded ChainGrade&lt;br&gt;  (DAIF→HASAN, capped)&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ 603/603 fires on real data&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=center;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1050" y="260" width="240" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="corr_no_label" value="NO" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#999999;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="1230" y="150" width="40" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="a_corr_no" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#999999;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="fork_corr" target="s5b">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s5b" value="&lt;b&gt;5b. NO CORROBORATION&lt;/b&gt;&lt;br&gt;Chain grade used as-is&lt;br&gt;(may already be DAIF/HASAN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;align=center;" vertex="1" parent="1">
                    <mxGeometry x="1320" y="95" width="190" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="a_rejoin1" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#28a745;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s5a" target="s6">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="a_rejoin2" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#999999;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="s5b" target="s6">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1415" y="510"/>
                            <mxPoint x="1415" y="510"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s6" value="&lt;b&gt;6. CONTENT CRITICISM (matn)&lt;/b&gt;&lt;br&gt;(critics/embedding.py | nli.py | llm.py)&lt;br&gt;&lt;br&gt;ContentCritic.evaluate(claim, norm, corpus, domain):&lt;br&gt;  EmbeddingCritic: TF-IDF cosine sim + contradiction heuristics&lt;br&gt;  HybridCritic: MiniLM retrieval → DeBERTa NLI judgment&lt;br&gt;  LocalNLICritic: DeBERTa cross-encoder NLI directly&lt;br&gt;  LLMCritic: Anthropic Claude with retrieval-augmented context&lt;br&gt;→ ContentVerdict: CONSISTENT | CONTRADICTION | UNVERIFIABLE&lt;br&gt;&lt;br&gt;&lt;i&gt;Evaluated independently of chain grade&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;align=center;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="60" y="520" width="480" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="a6" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#43a047;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s6" target="s7">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s7" value="&lt;b&gt;7. DECISION MATRIX&lt;/b&gt; (core/decision.py)&lt;br&gt;&lt;br&gt;decide(ChainGrade, ContentVerdict) → Action&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; cellspacing=&quot;0&quot; style=&quot;border-collapse:collapse;&quot;&gt;&lt;tr bgcolor=&quot;#e3f2fd&quot;&gt;&lt;td&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;CONSISTENT&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;CONTRADICTION&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td bgcolor=&quot;#e3f2fd&quot;&gt;&lt;b&gt;SAHIH&lt;/b&gt;&lt;/td&gt;&lt;td bgcolor=&quot;#d4edda&quot;&gt;SERVE&lt;/td&gt;&lt;td bgcolor=&quot;#fff3cd&quot;&gt;REVIEW&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td bgcolor=&quot;#e3f2fd&quot;&gt;&lt;b&gt;HASAN&lt;/b&gt;&lt;/td&gt;&lt;td bgcolor=&quot;#cce5ff&quot;&gt;SERVE_WITH_CAVEAT&lt;/td&gt;&lt;td bgcolor=&quot;#fff3cd&quot;&gt;REVIEW&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td bgcolor=&quot;#e3f2fd&quot;&gt;&lt;b&gt;DAIF&lt;/b&gt;&lt;/td&gt;&lt;td bgcolor=&quot;#fff3cd&quot;&gt;REVIEW&lt;/td&gt;&lt;td bgcolor=&quot;#f8d7da&quot;&gt;QUARANTINE&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td bgcolor=&quot;#e3f2fd&quot;&gt;&lt;b&gt;MAWDU&lt;/b&gt;&lt;/td&gt;&lt;td bgcolor=&quot;#f8d7da&quot;&gt;REJECT+QUARANTINE&lt;/td&gt;&lt;td bgcolor=&quot;#f8d7da&quot;&gt;REJECT+QUARANTINE&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;describe_action() → human-readable reason" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c62828;fontSize=10;align=center;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="60" y="705" width="480" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="out_serve" value="&lt;b&gt;SERVE&lt;/b&gt;&lt;br&gt;SAHIH/HASAN + CONSISTENT&lt;br&gt;→ Serve to user, cache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;align=center;" vertex="1" parent="1">
                    <mxGeometry x="620" y="715" width="180" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="a7_serve" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#28a745;exitX=1;exitY=0.3;entryX=0;entryY=0.5;" edge="1" parent="1" source="s7" target="out_serve">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="out_review" value="&lt;b&gt;REVIEW&lt;/b&gt;&lt;br&gt;Any ʿilal case, weak chain&lt;br&gt;→ Hold in review queue&lt;br&gt;→ Needs human adjudication" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ff9800;fontSize=11;align=center;" vertex="1" parent="1">
                    <mxGeometry x="620" y="785" width="180" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="a7_review" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#ff9800;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s7" target="out_review">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="out_quar" value="&lt;b&gt;QUARANTINE / REJECT&lt;/b&gt;&lt;br&gt;MAWDU narrator or DAIF+CONTRADICTION&lt;br&gt;→ Active containment&lt;br&gt;→ Narrator downgraded&lt;br&gt;→ Evidence logged immutably" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#dc3545;fontSize=11;align=center;" vertex="1" parent="1">
                    <mxGeometry x="620" y="860" width="180" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="a7_quar" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#dc3545;exitX=1;exitY=0.7;entryX=0;entryY=0.5;" edge="1" parent="1" source="s7" target="out_quar">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="feedback_arrow" value="" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#c62828;dashed=1;startArrow=classic;exitX=1;exitY=1;entryX=0;entryY=1;" edge="1" parent="1" source="out_review" target="s3">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1020" y="900"/>
                            <mxPoint x="1020" y="195"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="feedback_label" value="&lt;b&gt;jarḥ–taʿdīl FEEDBACK LOOP&lt;/b&gt;&lt;br&gt;Decisions → Evidence logged → Registry updated&lt;br&gt;Narrator grades evolve with evidence over time&lt;br&gt;POST /v1/evidence → Registry.record_evidence()" style="text;html=1;strokeColor=none;fillColor=#ffffff;fontSize=11;fontColor=#c62828;align=center;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="840" y="880" width="360" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="reg_detail_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#5c6bc0;dashed=1;opacity=30;" vertex="1" parent="1">
                    <mxGeometry x="860" y="970" width="700" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="reg_detail_label" value="Narrator Registry — Living (narrator, domain) Store" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontStyle=1;fontColor=#3949ab;" vertex="1" parent="1">
                    <mxGeometry x="880" y="978" width="450" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="reg_detail1" value="&lt;b&gt;Narrator Entry&lt;/b&gt;&lt;br&gt;Key: (narrator_id, domain)&lt;br&gt;Grade, ʿadālah, ḍabṭ&lt;br&gt;model_family, upstream_source&lt;br&gt;is_active flag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5c6bc0;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="880" y="1010" width="200" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="reg_detail2" value="&lt;b&gt;Evidence Log (append-only)&lt;/b&gt;&lt;br&gt;evidence_type, action (JARH/TADIL)&lt;br&gt;description, metadata_json&lt;br&gt;created_at timestamp&lt;br&gt;Immutable — never deleted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5c6bc0;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1100" y="1010" width="220" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="reg_detail3" value="&lt;b&gt;Transition Policies&lt;/b&gt;&lt;br&gt;BayesianTransitionPolicy (default)&lt;br&gt;  Beta(α,β) posterior → grade&lt;br&gt;ThresholdTransitionPolicy (legacy)&lt;br&gt;  Hardcoded counts&lt;br&gt;CalibratedThresholdPolicy&lt;br&gt;  Data-driven thresholds" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5c6bc0;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="880" y="1090" width="240" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="reg_detail4" value="&lt;b&gt;Actions&lt;/b&gt;&lt;br&gt;.register() .get_grade()&lt;br&gt;.get_metadata() .quarantine()&lt;br&gt;.bump_version() → UNGRADED&lt;br&gt;.record_evidence() → new grade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5c6bc0;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1140" y="1090" width="220" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="persist_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;opacity=40;" vertex="1" parent="1">
                    <mxGeometry x="60" y="960" width="780" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="persist_label" value="Persistence Layer (isnad/storage/, alembic/)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
                    <mxGeometry x="80" y="968" width="350" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="persist_detail" value="&lt;b&gt;SQLAlchemy 2.0+ ORM&lt;/b&gt;  |  PostgreSQL 16 (production)  |  SQLite (testing)&lt;br&gt;Tables: rijal_claims, chain_links, narrator_registry, narrator_evidence, review_queue&lt;br&gt;RegistryDB: .load() from DB → in-memory Registry → .flush() to DB&lt;br&gt;Alembic migrations: bcf1da0dec28 (initial schema — 5 tables + indexes, composite PKs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="998" width="740" height="45" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="validation" name="3. Validation Matrix">
        <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="vtitle" value="Validation Status — What Has Been Proven vs What Has Not" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
                    <mxGeometry x="350" y="15" width="900" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="proven_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;dashed=0;opacity=25;" vertex="1" parent="1">
                    <mxGeometry x="60" y="70" width="1480" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="proven_label" value="✅ EMPIRICALLY VALIDATED — Production Ready" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=15;fontStyle=1;fontColor=#155724;" vertex="1" parent="1">
                    <mxGeometry x="80" y="78" width="450" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="pv1" value="&lt;b&gt;Semantic Corroboration (mutābaʿāt)&lt;/b&gt;&lt;br&gt;603/603 (100%) semantically-matched cross-source claim pairs upgraded DAIF → HASAN&lt;br&gt;Dual Wikipedia corpus: 30 science topics, Regular EN + Simple EN (genuinely independent)&lt;br&gt;8/8 negative controls: shared narrator ID blocked, shared model family blocked,&lt;br&gt;shared upstream source blocked, SAHIH cap enforced, HASAN cap enforced&lt;br&gt;Information-theoretic weight calibration verified" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="115" width="700" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="pv2" value="&lt;b&gt;Independence Detection (madār)&lt;/b&gt;&lt;br&gt;SharedLineageDetector: shared narrator IDs → score 0.0 (blocked)&lt;br&gt;Shared model family → -0.4 penalty per family&lt;br&gt;Shared upstream source → -0.3 penalty per source&lt;br&gt;All gates independently verified in negative control suite" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="800" y="115" width="350" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="pv3" value="&lt;b&gt;Bayesian Narrator Grading&lt;/b&gt;&lt;br&gt;Beta(α,β) posterior mean → ordinal grade (RELIABLE ≥ 0.90, ACCEPTABLE ≥ 0.75,&lt;br&gt;WEAK ≥ 0.50, REJECTED &lt; 0.50)&lt;br&gt;BayesianTransitionPolicy is the DEFAULT (ISNAD_POLICY=bayesian)&lt;br&gt;21/21 wiring checks pass | Seed-grade bootstrapping validated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1170" y="115" width="350" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="pv4" value="&lt;b&gt;Chain Grading &amp; Weakest-Link&lt;/b&gt;&lt;br&gt;17 grading tests pass: all-RELIABLE → SAHIH | WEAK link → DAIF | REJECTED → MAWDU&lt;br&gt;Incomplete chain → DAIF cap | generative corroborated repair verified&lt;/mxCell&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="210" width="540" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="pv5" value="&lt;b&gt;Decision Matrix&lt;/b&gt;: all 12 cells tested | &lt;b&gt;EmbeddingCritic (TF-IDF)&lt;/b&gt;: functional, fast, zero-deps | &lt;b&gt;API&lt;/b&gt;: all endpoints tested" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="640" y="210" width="510" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="pv6" value="&lt;b&gt;LangChain Integration&lt;/b&gt;: 9 tests pass | &lt;b&gt;Database Persistence&lt;/b&gt;: SQLAlchemy + Alembic | &lt;b&gt;Semantic matching pipeline&lt;/b&gt;: cosine-based" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1170" y="210" width="350" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="pv7" value="&lt;b&gt;Cross-source claim matching&lt;/b&gt;: 603 semantically-matched pairs across Regular + Simple Wikipedia (cosine ≥ 0.75)&lt;br&gt;&lt;b&gt;S8 Gated vs Ungated Experiment&lt;/b&gt;: 4 conditions × 10 seeds × 4 budgets — wired and runnable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="270" width="1070" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="pv8" value="&lt;b&gt;LangChain IsnadTracer&lt;/b&gt;: callback handler auto-builds chains from LLM/retriever/tool events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1170" y="270" width="350" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="partial_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ff9800;dashed=0;opacity=25;" vertex="1" parent="1">
                    <mxGeometry x="60" y="390" width="1480" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="partial_label" value="⚠️ PARTIALLY VALIDATED — Wired but needs more testing / external deps" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=15;fontStyle=1;fontColor=#856404;" vertex="1" parent="1">
                    <mxGeometry x="80" y="398" width="600" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="pp1" value="&lt;b&gt;NLI Critics (HybridCritic, LocalNLICritic)&lt;/b&gt;&lt;br&gt;DeBERTa cross-encoder + MiniLM retriever. Model works when sentence-transformers installed.&lt;br&gt;HybridCritic is the recommended production critic. Graceful fallback to EmbeddingCritic.&lt;br&gt;Not tested at scale (slow inference on full corpus). ~500MB model download." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff9800;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="435" width="480" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="pp2" value="&lt;b&gt;LLMCritic (Anthropic Claude)&lt;/b&gt;&lt;br&gt;Wired with retrieval-augmented context + disk caching. Needs ANTHROPIC_API_KEY.&lt;br&gt;Not benchmarked against standardized corpus. Cost-gated. Graceful degradation to UNVERIFIABLE." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff9800;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="580" y="435" width="480" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="pp3" value="&lt;b&gt;jarḥ–taʿdīl Discovery Loop&lt;/b&gt;&lt;br&gt;Correctly identifies bad narrators. Good narrators need seed grades (cold-start problem).&lt;br&gt;Full feedback loop not exercised on real data. Coverage ~50% without seed grades." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff9800;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1080" y="435" width="440" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="pp4" value="&lt;b&gt;DeterministicRuleCritic&lt;/b&gt; (matn.py) — Reference stub: 8 hand-curated patterns only. Returns UNVERIFIABLE for real text.&lt;br&gt;&lt;b&gt;Cross-topic matching&lt;/b&gt;: 51% boilerplate in raw semantic matches, needs better filtering. &lt;b&gt;Confidence-gating&lt;/b&gt;: proven useless (self-confidence scores uncorrelated with defects)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff9800;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="510" width="1440" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="notdone_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#dc3545;dashed=0;opacity=25;" vertex="1" parent="1">
                    <mxGeometry x="60" y="610" width="1480" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="notdone_label" value="❌ NOT YET DONE — Open gaps / Future work" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=15;fontStyle=1;fontColor=#721c24;" vertex="1" parent="1">
                    <mxGeometry x="80" y="618" width="450" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="nd1" value="&lt;b&gt;Real LLM-generated claims&lt;/b&gt;&lt;br&gt;All current claims are extracted sentences from Wikipedia/text.&lt;br&gt;No testing on LLM hallucinations, confabulations, or model-introduced errors.&lt;br&gt;Cannot evaluate framework on its intended use case." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc3545;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="655" width="350" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="nd2" value="&lt;b&gt;Human ground-truth validation&lt;/b&gt;&lt;br&gt;Claims verified by semantic overlap, not checked against authoritative references.&lt;br&gt;No human-annotated corpus of true/corrupted claim pairs across domains.&lt;br&gt;Critical for real-world deployment safety." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc3545;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="450" y="655" width="350" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="nd3" value="&lt;b&gt;Full pipeline integration test&lt;/b&gt;&lt;br&gt;Chain → Grade → Critic → Corroborate → Decide — only individual steps tested in isolation.&lt;br&gt;No end-to-end test across the full lifecycle on diverse real-world data." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc3545;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="820" y="655" width="350" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="nd4" value="&lt;b&gt;Multi-source beyond Wikipedia&lt;/b&gt;&lt;br&gt;Britannica (JS-rendered, blocked). ArXiv, textbooks, news — not tested.&lt;br&gt;Multi-domain (beyond physics) — not tested. Non-English sources — not tested." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc3545;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1190" y="655" width="330" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="nd5" value="&lt;b&gt;Production hardening&lt;/b&gt;&lt;br&gt;No rate limiting, no auth beyond basic API keys, no distributed tracing, no load testing.&lt;br&gt;Redis included in compose but not integrated. Prometheus metrics are basic counters only." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc3545;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="80" y="735" width="700" height="40" as="geometry"/>
                </mxCell>
