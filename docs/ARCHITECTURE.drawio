        <mxCell id="critic_embed" value="&lt;b&gt;embedding.py — EmbeddingCritic&lt;/b&gt;&lt;br&gt;📊 TF-IDF weighted cosine sim&lt;br&gt;📊 Contradiction heuristics&lt;br&gt;📊 Zero dependencies, offline&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ Default critic | Functional&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="310" y="650" width="230" height="80" as="geometry" />
