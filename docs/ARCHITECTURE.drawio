        <mxCell id="critic_nli" value="&lt;b&gt;nli.py — LocalNLICritic&lt;/b&gt;&lt;br&gt;🤖 DeBERTa cross-encoder&lt;br&gt;🤖 HybridCritic: MiniLM→NLI&lt;br&gt;🤖 ~500MB model download&lt;br&gt;&lt;font color=&quot;#0077b6&quot;&gt;✅ Functional | Optional dep&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0077b6;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="560" y="650" width="230" height="80" as="geometry" />
        </mxCell>

        <mxCell id="critic_llm" value="&lt;b&gt;llm.py — LLMCritic&lt;/b&gt;&lt;br&gt;🧠 Anthropic Claude-backed&lt;br&gt;🧠 Retrieval-augmented context&lt;br&gt;🧠 Disk caching&lt;br&gt;&lt;font color=&quot;#ffc107&quot;&gt;⚠️ Needs API key | Untested at scale&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ffc107;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
