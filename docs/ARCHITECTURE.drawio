          <mxGeometry x="1070" y="650" width="230" height="80" as="geometry" />
        </mxCell>

        <mxCell id="critic_hybrid" value="&lt;b&gt;HybridCritic&lt;/b&gt; (nli.py)&lt;br&gt;2-stage: MiniLM retrieval → NLI judgment&lt;br&gt;Best accuracy/performance balance&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ Recommended for production&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
