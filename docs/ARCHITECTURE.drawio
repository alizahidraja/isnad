                <mxCell id="edge_rd" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#e91e63;dashed=1;startArrow=classic;exitX=0;exitY=0.85;entryX=1;entryY=0.5;" parent="1" source="reg_box" target="decision_box" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge_rd_label" value="jarḥ–taʿdīl feedback loop" style="text;html=1;strokeColor=none;fillColor=#ffffff;fontSize=10;fontColor=#e91e63;align=center;" parent="1" vertex="1">
