                <mxCell id="edge_crit_dec" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#43a047;dashed=1;exitX=0.5;exitY=1;entryX=1;entryY=1;" parent="1" source="critic_embed" target="decision_box" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
