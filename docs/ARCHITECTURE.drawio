                    <mxGeometry x="400" y="20" width="1000" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Every module, every relationship, every validation status. Package: isnad | Source: src/isnad/" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontColor=#888888;" parent="1" vertex="1">
