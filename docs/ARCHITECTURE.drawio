        <mxCell id="critic_base" value="&lt;b&gt;base.py&lt;/b&gt;&lt;br&gt;ContentCritic protocol&lt;br&gt;.evaluate(claim, norm, corpus, domain)&lt;br&gt;→ ContentVerdict&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ Protocol defined&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="650" width="220" height="80" as="geometry" />
