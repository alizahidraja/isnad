        <mxCell id="layer1_label" value="LAYER 1 — Core Engine (isnad/core/)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#0077b6;" vertex="1" parent="1">
          <mxGeometry x="55" y="288" width="300" height="20" as="geometry" />
        </mxCell>

        <!-- Chain -->
        <mxCell id="chain_box" value="&lt;b&gt;chain.py — Transmission Chain&lt;/b&gt;&lt;br&gt;&lt;br&gt;🔗 &lt;b&gt;ChainLinkSpec&lt;/b&gt;: narrator, step,&lt;br&gt;   version, transform_type, trace_id&lt;br&gt;🔗 &lt;b&gt;Chain&lt;/b&gt;: ordered links, gap-checked&lt;br&gt;   .is_complete → ittiṣāl (completeness)&lt;br&gt;   .chain_status → COMPLETE | MUNQATI&lt;br&gt;🔗 &lt;b&gt;store_claim()&lt;/b&gt; → RijalClaim ORM&lt;br&gt;🔗 &lt;b&gt;normalize_claim_text()&lt;/b&gt; + SHA-256 ID&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ 157 tests pass&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0077b6;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="315" width="280" height="140" as="geometry" />
        </mxCell>

        <!-- Registry -->
        <mxCell id="reg_box" value="&lt;b&gt;registry.py — Rijāl Registry&lt;/b&gt;&lt;br&gt;&lt;br&gt;📋 &lt;b&gt;Narrator&lt;/b&gt;: (id, domain) keyed&lt;br&gt;   grade, adalah, dabt, evidence_log&lt;br&gt;📋 &lt;b&gt;Registry&lt;/b&gt;: in-memory store&lt;br&gt;   .register(), .get_grade(), .record_evidence()&lt;br&gt;   .quarantine(), .bump_version()&lt;br&gt;📋 &lt;b&gt;RegistryDB&lt;/b&gt;: SQLAlchemy-backed&lt;br&gt;📋 &lt;b&gt;BayesianTransitionPolicy&lt;/b&gt; (DEFAULT)&lt;br&gt;   Beta(α,β) → posterior mean → grade&lt;br&gt;📋 ThresholdTransitionPolicy (fallback)&lt;br&gt;📋 CalibratedThresholdPolicy&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ Bayesian default | Domain-conditioned&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0077b6;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="360" y="315" width="300" height="175" as="geometry" />
        </mxCell>

        <!-- Grading -->
        <mxCell id="grading_box" value="&lt;b&gt;grading.py — Chain Grading&lt;/b&gt;&lt;br&gt;&lt;br&gt;⚖️ &lt;b&gt;RefinedWeakestLink&lt;/b&gt;&lt;br&gt;   Walks chain step-by-step:&lt;br&gt;   → DESTRUCTIVE: permanent hard floor&lt;br&gt;   → GENERATIVE: can repair (corroboration-gated)&lt;br&gt;   → PASS_THROUGH: standard min&lt;br&gt;   → Incomplete chain → DAIF cap&lt;br&gt;⚖️ &lt;b&gt;grade_chain()&lt;/b&gt; convenience&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ 17 tests | Pluggable protocol&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0077b6;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="680" y="315" width="260" height="145" as="geometry" />
        </mxCell>

        <!-- Corroboration -->
        <mxCell id="corr_box" value="&lt;b&gt;corroboration.py — Mutābaʿāt&lt;/b&gt;&lt;br&gt;&lt;br&gt;🔄 &lt;b&gt;SharedLineageDetector&lt;/b&gt;&lt;br&gt;   .are_independent() — madār detection&lt;br&gt;   .compute_independence_score()&lt;br&gt;   Penalties: shared IDs (0.0),&lt;br&gt;   shared family (-0.4), shared source (-0.3)&lt;br&gt;🔄 &lt;b&gt;CappedCorroborationPolicy&lt;/b&gt;&lt;br&gt;   Info-theoretic error multiplication&lt;br&gt;   MIN_EFFECTIVE_WEIGHT = 2.0 (configurable)&lt;br&gt;🔄 &lt;b&gt;CorroborationEngine&lt;/b&gt;&lt;br&gt;   .evaluate() — exact text matching&lt;br&gt;   .evaluate_direct() — pre-matched chains&lt;br&gt;🔄 &lt;b&gt;evaluate_corroboration()&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ Empirically validated | 603/603 claims&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ 8/8 negative controls | evaluate_direct() API&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0077b6;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="960" y="315" width="330" height="195" as="geometry" />
        </mxCell>

        <!-- Decision -->
        <mxCell id="decision_box" value="&lt;b&gt;decision.py — Decision Matrix&lt;/b&gt;&lt;br&gt;&lt;br&gt;🎯 &lt;b&gt;decide(chain_grade, content_verdict)&lt;/b&gt;&lt;br&gt;   4×2 matrix → Action enum&lt;br&gt;   SERVE | SERVE_WITH_CAVEAT | REVIEW&lt;br&gt;   QUARANTINE | REJECT_AND_QUARANTINE&lt;br&gt;🎯 &lt;b&gt;describe_action()&lt;/b&gt; — human-readable&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ All 12 cells tested&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0077b6;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="475" width="280" height="115" as="geometry" />
        </mxCell>

        <!-- MATN -->
        <mxCell id="matn_box" value="&lt;b&gt;matn.py — Content Criticism&lt;/b&gt;&lt;br&gt;&lt;br&gt;📝 &lt;b&gt;DeterministicRuleCritic&lt;/b&gt;&lt;br&gt;   Reference stub — pattern matching&lt;br&gt;   CONTRADICTION_PATTERNS: 8 pairs&lt;br&gt;   .add_pattern(), .evaluate()&lt;br&gt;&lt;font color=&quot;#ffc107&quot;&gt;⚠️ STUB — limited pattern coverage&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ffc107;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="680" y="478" width="260" height="112" as="geometry" />
        </mxCell>

        <!-- Storage -->
        <mxCell id="storage_box" value="&lt;b&gt;storage/ — Persistence&lt;/b&gt;&lt;br&gt;&lt;br&gt;💾 &lt;b&gt;StorageBackend (protocol)&lt;/b&gt;&lt;br&gt;💾 &lt;b&gt;SQLAlchemyStorage&lt;/b&gt;&lt;br&gt;   .save_claim(), .save_narrator()&lt;br&gt;   .save_evidence(), .get_chain()&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✅ SQLAlchemy-backed | Swap via protocol&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0077b6;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="360" y="508" width="300" height="82" as="geometry" />
