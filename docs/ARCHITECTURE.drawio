  <diagram id="dataflow" name="2. Claim Lifecycle">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <mxCell id="title2" value="Claim Lifecycle — End-to-End Data Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="350" y="15" width="700" height="35" as="geometry" />
        </mxCell>

        <!-- Step 1: Source -->
        <mxCell id="s1" value="&lt;b&gt;1. SOURCE&lt;/b&gt;&lt;br&gt;Wikipedia, PDF, API,&lt;br&gt;database, user input&lt;br&gt;&lt;br&gt;&lt;i&gt;Raw text enters system&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a1" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976d2;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="240" y="120" as="sourcePoint" />
            <mxPoint x="310" y="120" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 2: Extraction -->
        <mxCell id="s2" value="&lt;b&gt;2. EXTRACTION&lt;/b&gt;&lt;br&gt;Sentence split, OCR,&lt;br&gt;LLM claim extraction&lt;br&gt;&lt;br&gt;&lt;i&gt;Creates ChainLinkSpec&lt;/i&gt;&lt;br&gt;&lt;i&gt;narrator_id, step, transform&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="310" y="80" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a2" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976d2;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="490" y="120" as="sourcePoint" />
            <mxPoint x="560" y="120" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 3: Chain -->
        <mxCell id="s3" value="&lt;b&gt;3. CHAIN BUILDING&lt;/b&gt;&lt;br&gt;Chain(links) → gap check&lt;br&gt;.is_complete → ittiṣāl&lt;br&gt;.narrator_ids → ordered&lt;br&gt;&lt;br&gt;&lt;i&gt;store_claim() → DB&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="560" y="80" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a3" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976d2;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="740" y="120" as="sourcePoint" />
            <mxPoint x="810" y="120" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 4: Registry lookup -->
        <mxCell id="s4" value="&lt;b&gt;4. NARRATOR GRADING&lt;/b&gt;&lt;br&gt;Registry.get_grade(narrator, domain)&lt;br&gt;BayesianTransitionPolicy (default)&lt;br&gt;Beta(α,β) posterior → grade&lt;br&gt;&lt;br&gt;&lt;i&gt;Domain-conditioned lookups&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="810" y="70" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="a4" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976d2;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1010" y="120" as="sourcePoint" />
            <mxPoint x="1080" y="120" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 5: Chain Grading -->
        <mxCell id="s5" value="&lt;b&gt;5. CHAIN GRADING&lt;/b&gt;&lt;br&gt;RefinedWeakestLink&lt;br&gt;→ Destructive: hard floor&lt;br&gt;→ Generative: can repair&lt;br&gt;→ Incomplete: DAIF cap&lt;br&gt;&lt;br&gt;&lt;i&gt;grade_chain() → ChainGrade&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1080" y="70" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Fork -->
        <mxCell id="fork" value="" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ffc107;" vertex="1" parent="1">
          <mxGeometry x="1145" y="220" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="a5a" value="Corroboration?" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#ffc107;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1180" y="170" as="sourcePoint" />
            <mxPoint x="1185" y="220" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Left: Corroboration path -->
        <mxCell id="a5b" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#28a745;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1145" y="240" as="sourcePoint" />
            <mxPoint x="400" y="240" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="a5b_label" value="YES — independent chains exist" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#28a745;" vertex="1" parent="1">
          <mxGeometry x="500" y="225" width="180" height="15" as="geometry" />
        </mxCell>

        <!-- Right: No corroboration -->
        <mxCell id="a5c" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1225" y="240" as="sourcePoint" />
            <mxPoint x="1225" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="a5c_label" value="NO" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="1260" y="230" width="30" height="15" as="geometry" />
        </mxCell>

        <!-- Step 6a: Corroboration -->
        <mxCell id="s6a" value="&lt;b&gt;6a. CORROBORATION&lt;/b&gt;&lt;br&gt;CorroborationEngine.evaluate_direct()&lt;br&gt;1) Independence check (madār)&lt;br&gt;2) Min grade gate (≥ HASAN)&lt;br&gt;3) Count gate (≥ min_independent_chains)&lt;br&gt;4) Info-theoretic weight → upgrade?&lt;br&gt;&lt;br&gt;&lt;i&gt;DAIF → HASAN (capped, never SAHIH)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="230" y="260" width="260" height="120" as="geometry" />
        </mxCell>

        <mxCell id="a6a" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#28a745;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="360" y="380" as="sourcePoint" />
            <mxPoint x="360" y="430" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 7: Content Criticism -->
        <mxCell id="s7" value="&lt;b&gt;7. CONTENT CRITICISM&lt;/b&gt;&lt;br&gt;EmbeddingCritic (TF-IDF) / HybridCritic (NLI)&lt;br&gt;.evaluate(claim, normalized, corpus, domain)&lt;br&gt;→ ContentVerdict: CONSISTENT | CONTRADICTION | UNVERIFIABLE&lt;br&gt;&lt;br&gt;&lt;i&gt;Independent of chain grade&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="140" y="430" width="440" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a7" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1976d2;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="360" y="510" as="sourcePoint" />
            <mxPoint x="360" y="560" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 8: Decision -->
        <mxCell id="s8" value="&lt;b&gt;8. DECISION MATRIX&lt;/b&gt;&lt;br&gt;decide(chain_grade, content_verdict) → Action&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;2&quot;&gt;&lt;tr&gt;&lt;td&gt;&lt;/td&gt;&lt;td&gt;CONSISTENT&lt;/td&gt;&lt;td&gt;CONTRADICTION&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;SAHIH&lt;/td&gt;&lt;td bgcolor=&quot;#d4edda&quot;&gt;SERVE&lt;/td&gt;&lt;td bgcolor=&quot;#fff3cd&quot;&gt;REVIEW&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;HASAN&lt;/td&gt;&lt;td bgcolor=&quot;#cce5ff&quot;&gt;CAVEAT&lt;/td&gt;&lt;td bgcolor=&quot;#fff3cd&quot;&gt;REVIEW&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;DAIF&lt;/td&gt;&lt;td bgcolor=&quot;#fff3cd&quot;&gt;REVIEW&lt;/td&gt;&lt;td bgcolor=&quot;#f8d7da&quot;&gt;QUARANTINE&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;MAWDU&lt;/td&gt;&lt;td bgcolor=&quot;#f8d7da&quot;&gt;REJECT&lt;/td&gt;&lt;td bgcolor=&quot;#f8d7da&quot;&gt;REJECT&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e91e63;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="145" y="560" width="430" height="140" as="geometry" />
        </mxCell>

        <!-- Step 6b: No corroboration path -->
        <mxCell id="s6b" value="&lt;b&gt;6b. NO CORROBORATION&lt;/b&gt;&lt;br&gt;Chain grade used as-is&lt;br&gt;(may already be DAIF/HASAN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1115" y="370" width="210" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a6b" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1220" y="420" as="sourcePoint" />
            <mxPoint x="1220" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="a6b_join" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1220" y="490" as="sourcePoint" />
            <mxPoint x="580" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Evidence feedback loop -->
        <mxCell id="feedback" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#e91e63;dashed=1;startArrow=classic;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="580" y="630" as="sourcePoint" />
            <mxPoint x="1010" y="120" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="feedback_label" value="&lt;b&gt;jarḥ–taʿdīl FEEDBACK LOOP&lt;/b&gt;&lt;br&gt;Decision → Evidence → Registry update&lt;br&gt;Narrator grades evolve over time" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#e91e63;align=center;" vertex="1" parent="1">
          <mxGeometry x="580" y="640" width="280" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="validation" name="3. Validation Matrix">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <mxCell id="vtitle" value="Validation Status — What's Proven vs What's Not" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="300" y="15" width="800" height="35" as="geometry" />
        </mxCell>

        <!-- PROVEN -->
        <mxCell id="proven_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;dashed=0;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="1320" height="260" as="geometry" />
        </mxCell>
        <mxCell id="proven_label" value="✅ EMPIRICALLY VALIDATED — Production Ready" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;fontStyle=1;fontColor=#155724;" vertex="1" parent="1">
          <mxGeometry x="55" y="75" width="400" height="25" as="geometry" />
        </mxCell>

        <mxCell id="pv1" value="&lt;b&gt;Corroboration fires on real data&lt;/b&gt;&lt;br&gt;603/603 (100%) semantically-matched&lt;br&gt;cross-source claim pairs upgraded&lt;br&gt;DAIF → HASAN. 8/8 negative controls.&lt;br&gt;Dual Wikipedia corpus (en + simple)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="300" height="80" as="geometry" />
        </mxCell>

        <mxCell id="pv2" value="&lt;b&gt;Independence detection (madār)&lt;/b&gt;&lt;br&gt;Shared narrator IDs → blocked&lt;br&gt;Shared model family → blocked&lt;br&gt;Shared upstream source → blocked&lt;br&gt;All gates verified independently." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="380" y="110" width="300" height="80" as="geometry" />
        </mxCell>

        <mxCell id="pv3" value="&lt;b&gt;Bayesian narrator grading&lt;/b&gt;&lt;br&gt;Beta-distribution default policy&lt;br&gt;Jarḥ evidence → REJECTED (3 JARH)&lt;br&gt;Taʿdīl evidence → RELIABLE (10 TADIL)&lt;br&gt;21/21 wiring checks pass." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="700" y="110" width="300" height="80" as="geometry" />
        </mxCell>

        <mxCell id="pv4" value="&lt;b&gt;Chain grading &amp; weakest-link&lt;/b&gt;&lt;br&gt;All RELIABLE → SAHIH&lt;br&gt;RELIABLE + WEAK → DAIF&lt;br&gt;Incomplete chain → DAIF cap&lt;br&gt;REJECTED narrator → MAWDU&lt;br&gt;17 grading tests pass." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1020" y="110" width="300" height="80" as="geometry" />
        </mxCell>

        <mxCell id="pv5" value="&lt;b&gt;Decision matrix (all 12 cells)&lt;/b&gt; | &lt;b&gt;API endpoints&lt;/b&gt; | &lt;b&gt;LangChain integration (9 tests)&lt;/b&gt; | &lt;b&gt;EmbeddingCritic (TF-IDF)&lt;/b&gt; | &lt;b&gt;Database persistence&lt;/b&gt; | &lt;b&gt;Semantic matching pipeline&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#28a745;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="1260" height="50" as="geometry" />
        </mxCell>

        <!-- PARTIAL -->
        <mxCell id="partial_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ffc107;dashed=0;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="1320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="partial_label" value="⚠️ PARTIALLY VALIDATED — Wired but needs more testing" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;fontStyle=1;fontColor=#856404;" vertex="1" parent="1">
          <mxGeometry x="55" y="355" width="450" height="25" as="geometry" />
        </mxCell>

        <mxCell id="pp1" value="&lt;b&gt;NLI Critics (HybridCritic, LocalNLICritic)&lt;/b&gt;&lt;br&gt;DeBERTa cross-encoder model works.&lt;br&gt;Graceful degradation when model absent.&lt;br&gt;Not tested at scale (slow inference)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffc107;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="390" width="400" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pp2" value="&lt;b&gt;LLMCritic (Anthropic)&lt;/b&gt;&lt;br&gt;Wired with retrieval-augmented context.&lt;br&gt;Needs API key. Not benchmarked.&lt;br&gt;No standardized test corpus." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffc107;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="480" y="390" width="400" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pp3" value="&lt;b&gt;jarḥ–taʿdīl discovery loop&lt;/b&gt;&lt;br&gt;Correctly identifies bad narrators.&lt;br&gt;Good narrators need seed grades.&lt;br&gt;Full feedback loop not exercised on real data." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffc107;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="900" y="390" width="420" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pp4" value="&lt;b&gt;DeterministicRuleCritic&lt;/b&gt; (matn.py) — REFERENCE STUB — 8 hardcoded patterns only | &lt;b&gt;S8 gated vs ungated&lt;/b&gt; — Experiment wired but coverage collapses without seed grades | &lt;b&gt;Cross-topic matching&lt;/b&gt; — 51% boilerplate in raw matches, needs better filtering" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffc107;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="465" width="1260" height="50" as="geometry" />
        </mxCell>

        <!-- NOT DONE -->
        <mxCell id="notdone_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#dc3545;dashed=0;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="40" y="550" width="1320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="notdone_label" value="❌ NOT YET DONE — Future Work" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;fontStyle=1;fontColor=#721c24;" vertex="1" parent="1">
          <mxGeometry x="55" y="555" width="300" height="25" as="geometry" />
        </mxCell>

        <mxCell id="nd1" value="&lt;b&gt;Real LLM-generated claims&lt;/b&gt;&lt;br&gt;All current claims are extracted sentences.&lt;br&gt;No LLM hallucination/confabulation testing." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc3545;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="590" width="300" height="65" as="geometry" />
        </mxCell>

        <mxCell id="nd2" value="&lt;b&gt;Human ground truth validation&lt;/b&gt;&lt;br&gt;Claims verified by semantic overlap,&lt;br&gt;not checked against authoritative refs." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc3545;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="380" y="590" width="300" height="65" as="geometry" />
        </mxCell>

        <mxCell id="nd3" value="&lt;b&gt;Full pipeline integration test&lt;/b&gt;&lt;br&gt;Chain→Grade→Critic→Corroborate→Decide&lt;br&gt;Only individual steps tested." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc3545;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="700" y="590" width="300" height="65" as="geometry" />
        </mxCell>

        <mxCell id="nd4" value="&lt;b&gt;Multi-source beyond Wikipedia&lt;/b&gt;&lt;br&gt;Britannica (JS-rendered, blocked)&lt;br&gt;ArXiv, textbooks, news — not tested.&lt;br&gt;Confidence-gating — proven useless." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dc3545;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1020" y="590" width="300" height="65" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
